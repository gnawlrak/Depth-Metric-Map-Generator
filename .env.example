# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# HF_TOKEN: Hugging Face API Token (optional, used for higher rate limits on Spaces)
HF_TOKEN=""

# PYTHON_BACKEND_URL: URL of the optional Python inference backend for Depth Anything V2 and Metric3D.
# If not set or unreachable, the Node server falls back to JS/ONNX inference.
PYTHON_BACKEND_URL="http://127.0.0.1:3001"

# POINTCLOUD_BACKEND_URL: Internal URL of the point-cloud service (Node proxies to it).
POINTCLOUD_BACKEND_URL="http://127.0.0.1:3002"

# PUBLIC_POINTCLOUD_URL (optional): Public base URL for point-cloud viewer links.
# If not set, the viewer URL is inferred from the incoming request host.
# Use this when running behind a reverse proxy or when direct request inference fails.
# PUBLIC_POINTCLOUD_URL="https://10.0.170.72:3000"
