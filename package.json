{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:https": "npm run generate-cert && tsx server.ts --https",
    "dev:all:https": "npm run generate-cert && concurrently \"npm run dev:python\" \"npm run dev:pointcloud\" \"tsx server.ts --https\"",
    "generate-cert": "node scripts/generate-cert.mjs",
    "dev:python": "python python_backend/inference_server.py",
    "dev:pointcloud": "python python_backend/pointcloud_server.py",
    "dev:all": "concurrently \"npm run dev:python\" \"npm run dev:pointcloud\" \"npm run dev\"",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@gradio/client": "^2.3.0",
    "@huggingface/inference": "^4.13.19",
    "@tailwindcss/vite": "^4.1.14",
    "@techstark/opencv-js": "^4.10.0-release.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@xenova/transformers": "^2.17.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "pngjs": "^7.0.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-dropzone": "^15.0.0",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/pngjs": "^6.0.5",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "esbuild": "^0.25.0",
    "selfsigned": "^5.5.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
